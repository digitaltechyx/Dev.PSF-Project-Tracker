
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // --- NOTIFICATIONS RULES ---
    match /notifications/{notificationId} {
      // Allow single document reads if the user is the recipient
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      // Allow collection queries (list) if they are filtered by the user's own ID
      // Firestore requires the query to have a matching .where("userId", "==", auth.uid) filter
      allow list: if isSignedIn() && (
        request.query.limit <= 100 && 
        resource.data.userId == request.auth.uid
      );
      
      // Allow creation by any authenticated user (actor)
      allow create: if isSignedIn() && request.resource.data.actorId == request.auth.uid;
      
      // Allow updates (mark as read) and deletes by the recipient only
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // --- COLLECTION GROUP RULES ---
    
    match /{path=**}/tasks/{taskId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /{path=**}/comments/{commentId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // --- HIERARCHICAL RULES ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /workspaces/{workspaceId} {
      allow read, create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.ownerUserId == request.auth.uid;

      match /members/{memberUserId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }

      match /projects/{projectId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();

        match /tasks/{taskId} {
          allow read: if isSignedIn();
          allow write: if isSignedIn();

          match /comments/{commentId} {
            allow read: if isSignedIn();
            allow write: if isSignedIn();
          }
        }
      }
    }
  }
}
